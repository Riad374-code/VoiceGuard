<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_background"
    android:clipToOutline="true"
    android:elevation="14dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_overlay_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.08"
        android:text="GUARDVOICE CALL CHECK"
        android:textColor="#6C675B"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/overlay_title"
        android:textColor="#1D1A16"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_overlay_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="3dp"
        android:text="@string/overlay_body"
        android:textColor="#5B564C"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_verdict"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Waiting for consent"
        android:textColor="#8A5A18"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_yes"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/overlay_button_primary"
            android:text="@string/overlay_allow"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Space
            android:layout_width="10dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btn_no"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/overlay_button_secondary"
            android:text="@string/overlay_decline"
            android:textAllCaps="false"
            android:textColor="#262118" />
    </LinearLayout>
</LinearLayout>
